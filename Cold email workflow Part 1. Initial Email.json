      "parameters": {
        "jsCode": "// ── Per-item duplicate check — runs fresh each loop iteration ──\nconst BLOCKING = ['sent','followup_1','completed','replied','unsubscribed'];\n\n// Current lead from the loop (1 item at a time)\nconst lead = $('Loop Over Items').item.json;\nconst leadEmail = (lead['Email'] || '').toLowerCase().trim();\n\n// Check tracking sheet rows\nconst alreadyTracked = $input.all().some(row => {\n  const rowEmail = (row.json['Email'] || row.json['email'] || '').toLowerCase().trim();\n  const rowStatus = (row.json['status'] || row.json['Status'] || '').toLowerCase().trim();\n  return rowEmail === leadEmail && BLOCKING.includes(rowStatus);\n});\n\nif (alreadyTracked) return [];\nreturn [{ json: lead }];\n"
      },
