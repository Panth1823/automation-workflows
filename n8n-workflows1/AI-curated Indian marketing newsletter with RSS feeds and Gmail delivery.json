7cb549d-88a7-4924-ae24-12283025b6e5","name":"Get row(s)","type":"n8n-nodes-base.dataTable","position":[1152,304],"typeVersion":1},{"parameters":{"operation":"deleteRows","dataTableId":{"__rl":true,"mode":"list","value":"1VUgEWZhtGRgWRc4","cachedResultUrl":"/projects/wdXsYqO0TAnlH2nc/datatables/1VUgEWZhtGRgWRc4","cachedResultName":"Newsletter"},"filters":{"conditions":[{"keyName":"Output","keyValue":"true"}]},"options":{}},"id":"e42b2ca9-83b7-4263-afbc-cbfb63eabcca","name":"Delete row(s)","type":"n8n-nodes-base.dataTable","position":[2112,208],"typeVersion":1},{"parameters":{},"id":"8ec7949d-2752-4608-981b-a2d1435de61e","name":"Limit","type":"n8n-nodes-base.limit","position":[944,304],"typeVersion":1},{"parameters":{},"id":"10ca706a-64ac-45c7-adfc-a388beec0e8e","name":"Merge Feeds-1","type":"n8n-nodes-base.merge","position":[-32,688],"typeVersion":1},{"parameters":{},"id":"92f8b000-dbd1-427a-87c9-888f5acfbd8a","name":"Merge Feeds-2","type":"n8n-nodes-base.merge","position":[-32,976],"typeVersion":1},{"parameters":{},"id":"7d4ccbbe-60da-44d7-9c92-9f72a1b4539d","name":"Merge Feeds-All","type":"n8n-nodes-base.merge","position":[208,816],"typeVersion":1},{"parameters":{"content":"## Get Latest News\n**Fetches 4 marketing news feeds (ET + Campaign India).\nYou can add/remove RSS sources here.**","height":727,"width":512,"color":7},"id":"ab8940f2-d075-417a-a2a3-9cf89c49fed3","name":"Sticky Note6","type":"n8n-nodes-base.stickyNote","position":[-736,512],"typeVersion":1},{"parameters":{"content":"## Merge all\n**Combines all RSS feeds into one list.**\n","height":727,"width":512,"color":7},"id":"9b1b5af8-479a-4eb7-9a31-fd6a99a92bb4","name":"Sticky Note7","type":"n8n-nodes-base.stickyNote","position":[-128,512],"typeVersion":1},{"parameters":{"content":"## Process AND LOOP-OVER All News Items\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\nEach article is passed to the AI Agent.\nThe agent returns true/false based on strict marketing relevance rules (System Prompt).\nModify the prompt in AI Agent if you want different filtering criteria.\n","height":615,"width":1520,"color":7},"id":"824e725a-a20b-46be-94c0-c6d791ed6879","name":"Sticky Note8","type":"n8n-nodes-base.stickyNote","position":[448,720],"typeVersion":1},{"parameters":{"content":"## Send Filtered News Using Gmail/SMTP Account\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\nThese nodes creates a polished HTML newsletter using the latest filtered articles from the Data Table. \nThe Code node formats the content with titles, links, publish dates, and snippets, producing the final subject and HTML body used for sending.\nAfter the email is sent, the workflow deletes all Data Table rows where Output = true.\n","height":519,"width":1520,"color":7},"id":"42428bc6-bc0d-406b-ad10-507f3e20602b","name":"Sticky Note9","type":"n8n-nodes-base.stickyNote","position":[816,128],"typeVersion":1},{"parameters":{"content":"## Set up steps - What this workflow does!\n\nThis flow pulls the latest marketing news from Campaign India and ET BrandEquity, filters the useful stories with an AI relevance check, saves them to a Data Table, and sends a daily newsletter at 7:30 PM IST. After sending, it clears the used entries so the next email contains only new articles.\n\n\n**How to set it up**\n1. Add your Gmail account.\n2. (Optional) Add SMTP if you want a fallback sender.\n3. Update the “Send to” email address.\n4. Create a Data Table in n8n, make sure the Data Table has all the columns as in 'Insert Roe' node or let n8n create it.\n5. Change the schedule time if needed.\n6. Add/remove RSS feeds in the “Get Latest News” group.","height":704,"width":420},"id":"182c2d6a-8ce6-41fb-b5eb-a8f29fd7e748","name":"Sticky Note1","type":"n8n-nodes-base.stickyNote","position":[-1600,528],"typeVersion":1}],"connections":{"If":{"main":[[{"node":"Insert row","type":"main","index":0}],[{"node":"Loop Over Items","type":"main","index":0}]]},"Code":{"main":[[{"node":"Send a message","type":"main","index":0}]]},"Limit":{"main":[[{"node":"Get row(s)","type":"main","index":0}]]},"Merge":{"main":[[{"node":"If","type":"main","index":0}]]},"AI Agent":{"main":[[{"node":"Merge","type":"main","index":0}]]},"Get row(s)":{"main":[[{"node":"Code","type":"main","index":0}]]},"Insert row":{"main":[[{"node":"Loop Over Items","type":"main","index":0}]]},"Send Email":{"main":[[{"node":"Delete row(s)","type":"main","index":0}]]},"Merge Feeds-1":{"main":[[{"node":"Merge Feeds-All","type":"main","index":0}]]},"Merge Feeds-2":{"main":[[{"node":"Merge Feeds-All","type":"main","index":1}]]},"Campaign India":{"main":[[{"node":"Merge Feeds-1","type":"main","index":0}]]},"Send a message":{"main":[[{"node":"Delete row(s)","type":"main","index":0}],[{"node":"Send Email","type":"main","index":0}]]},"Loop Over Items":{"main":[[{"node":"Limit","type":"main","index":0}],[{"node":"AI Agent","type":"main","index":0},{"node":"Merge","type":"main","index":1}]]},"Merge Feeds-All":{"main":[[{"node":"Loop Over Items","type":"main","index":0}]]},"Schedule Trigger":{"main":[[{"node":"EconomicTimes Top Stories1","type":"main","index":0},{"node":"EconomicTimes Business of Brands","type":"main","index":0},{"node":"EconomicTimes Digital Marketing","type":"main","index":0},{"node":"Campaign India","type":"main","index":0}]]},"OpenAI Chat Model":{"ai_languageModel":[[{"node":"AI Agent","type":"ai_languageModel","index":0}]]},"EconomicTimes Top Stories1":{"main":[[{"node":"Merge Feeds-1","type":"main","index":1}]]},"EconomicTimes Digital Marketing":{"main":[[{"node":"Merge Feeds-2","type":"main","index":1}]]},"EconomicTimes Business of Brands":{"main":[[{"node":"Merge Feeds-2","type":"main","index":0}]]}},"settings":{"executionOrder":"v1"},"staticData":null,"meta":{"templateCredsSetupCompleted":true},"pinData":{},"versionId":"8aecf6bf-f711-42f6-a5fb-808b9a58856d","activeVersionId":null,"triggerCount":0,"shared":[{"updatedAt":"2026-01-02T07:23:45.269Z","createdAt":"2026-01-02T07:23:45.269Z","rol