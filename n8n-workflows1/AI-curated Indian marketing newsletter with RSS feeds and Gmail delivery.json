[{"updatedAt":"2026-01-02T07:23:45.263Z","createdAt":"2026-01-02T07:23:45.263Z","id":"kTPMrUziT25QfTj6","name":"AI-curated Indian marketing newsletter with RSS feeds and Gmail delivery","active":false,"isArchived":false,"nodes":[{"parameters":{"fromEmail":"user@example.com","toEmail":"user@example.com","subject":"={{$json[\"subject\"]}}","html":"={{$json[\"htmlBody\"]}}","options":{}},"id":"6c8a1d1e-4620-453e-b3bc-5049c97d04cc","name":"Send Email","type":"n8n-nodes-base.emailSend","position":[1808,384],"typeVersion":1,"onError":"continueErrorOutput"},{"parameters":{"promptType":"define","text":"=You are a strict relevance filter for news articles.\n\nINSTRUCTIONS:\n- Reply only with: true or false\n- No explanations, no punctuation, no newlines, no extra text\n\nRELEVANT TOPICS:\n- Brand or product launches\n- New or upcoming advertising/marketing campaigns\n- Digital media changes (strategies, platforms, or tools)\n\nEvaluate the following article:\n\nTitle: {{ $json.title }}\nContent: {{ $json.content }}\nSnippet: {{ $json.contentSnippet }}\n\nIs this article relevant? Respond with true or false only.\n","options":{}},"id":"905f714b-66e3-4bb1-9dc1-941f9e10469c","name":"AI Agent","type":"@n8n/n8n-nodes-langchain.agent","position":[832,832],"executeOnce":true,"typeVersion":1.9,"onError":"continueErrorOutput"},{"parameters":{"options":{"reset":false}},"id":"b861ce16-a94a-4bbe-b592-bb1d7b200257","name":"Loop Over Items","type":"n8n-nodes-base.splitInBatches","position":[544,816],"typeVersion":3},{"parameters":{"mode":"combine","combineBy":"combineByPosition","options":{}},"id":"c45cd790-48f8-41ec-8946-a7d2e65eae71","name":"Merge","type":"n8n-nodes-base.merge","position":[1232,960],"typeVersion":3.1},{"parameters":{"conditions":{"options":{"version":2,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"id":"2f473722-ac3b-485f-b3de-6d4406b75e12","operator":{"type":"string","operation":"contains"},"leftValue":"={{ $json.output }}","rightValue":"true"}]},"options":{}},"id":"2f4503e3-f37f-4bd2-b194-30040ddd7eed","name":"If","type":"n8n-nodes-base.if","position":[1440,960],"typeVersion":2.2},{"parameters":{"rule":{"interval":[{"field":"cronExpression","expression":"30 19 * * *"}]}},"id":"adec9e01-6cdb-4ac4-9558-b9508e67b84b","name":"Schedule Trigger","type":"n8n-nodes-base.scheduleTrigger","position":[-960,832],"notesInFlow":false,"typeVersion":1.2},{"parameters":{"jsCode":"const tz = \"Asia/Kolkata\";\nconst now = new Date().toLocaleString(\"en-IN\", { timeZone: tz });\n\nconst articles = items.map(it => {\n  const j = it.json;\n\n  return `\n    <div style=\"padding:16px; border:1px solid #eee; border-radius:8px; margin-bottom:20px; background-color:#f9f9f9;\">\n      <h3 style=\"margin-top:0; margin-bottom:8px;\">\n        <a href=\"${j.Link}\" target=\"_blank\" style=\"color:#0077cc; text-decoration:none;\">\n          ${j.Title}\n        </a>\n      </h3>\n      <p style=\"margin:0 0 6px 0; font-size:13px; color:#888;\">\n        Published on: ${new Date(j.IsoDate).toLocaleDateString(\"en-IN\", { day: 'numeric', month: 'short', year: 'numeric' })}\n      </p>\n      <p style=\"margin:0; font-size:15px; line-height:1.6; color:#333;\">\n        ${j.ContentSnippet || ''}\n      </p>\n    </div>\n  `;\n}).join(\"\");\n\nreturn [{\n  json: {\n    subject: `XYZ Marketing NewsLetter – ${now}`,\n    htmlBody: `\n      <div style=\"font-family:'Segoe UI', Roboto, sans-serif; padding:24px; background-color:#ffffff; color:#333; max-width:700px; margin:auto;\">\n        <h2 style=\"color:#111; margin-top:0;\">📢 Latest Brand & Campaign Updates</h2>\n        ${articles}\n        <hr style=\"border:none; border-top:1px solid #ddd; margin:24px 0;\">\n        <p style=\"font-size:12px; color:#999; text-align:center;\">\n          Sent automatically by our XYZ newsletter assistant from Delhi.\n        </p>\n      </div>\n    `\n  }\n}];\n"},"id":"6e180adc-646b-475f-9e3d-9953267ffdbc","name":"Code","type":"n8n-nodes-base.code","position":[1360,304],"typeVersion":2},{"parameters":{"url":"https://brandequity.economictimes.indiatimes.com/rss/topstories","options":{"ignoreSSL":false}},"id":"228e6ff2-bdd1-4957-ae10-6265d9890d15","name":"EconomicTimes Top Stories1","type":"n8n-nodes-base.rssFeedRead","position":[-432,704],"typeVersion":1,"onError":"continueRegularOutput"},{"parameters":{"url":"https://brandequity.economictimes.indiatimes.com/rss/business-of-brands","options":{}},"id":"96fa0a7e-c9ea-496c-8788-929cf63cacf4","name":"EconomicTimes Business of Brands","type":"n8n-nodes-base.rssFeedRead","position":[-416,960],"typeVersion":1,"onError":"continueRegularOutput"},{"parameters":{"url":"https://brandequity.economictimes.indiatimes.com/rss/digital","options":{}},"id":"40532c1a-1e5b-48db-a5d1-e31c136e755a","name":"EconomicTimes Digital Marketing","type":"n8n-nodes-base.rssFeedRead","position":[-624,992],"typeVersion":1,"onError":"continueRegularOutput"},{"parameters":{"url":"https://www.campaignindia.in/rss/rss.ashx","options":{"ignoreSSL":false}},"id":"2586460c-0693-4471-8471-100845d98137","name":"Campaign India","type":"n8n-nodes-base.rssFeedRead","position":[-624,672],"typeVersion":1,"onError":"continueRegularOutput"},{"parameters":{"sendTo":"user@example.com","subject":"={{ $json.subject }}","message":"={{ $json.htmlBody }}","options":{}},"id":"055aaf2b-8b2d-4dcd-9a6e-78a6971e1123","name":"Send a message","type":"n8n-nodes-base.gmail","position":[1584,304],"webhookId":"dd1709b7-5299-4f99-8222-60eb5694136a","typeVersion":2.1,"alwaysOutputData":false,"onError":"continueErrorOutput"},{"parameters":{"model":{"__rl":true,"mode":"list","value":"gpt-5-mini","cachedResultName":"gpt-5-mini"},"options":{}},"id":"773d6638-5ae1-43e7-b62c-bf9f5010fcb1","name":"OpenAI Chat Model","type":"@n8n/n8n-nodes-langchain.lmChatOpenAi","position":[832,1008],"typeVersion":1.2},{"parameters":{"dataTableId":{"__rl":true,"mode":"list","value":"1VUgEWZhtGRgWRc4","cachedResultUrl":"/projects/