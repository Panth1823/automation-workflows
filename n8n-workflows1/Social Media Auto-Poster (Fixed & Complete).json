 item.json.id_str || \n    item.json.data?.id\n  );\n  if (twitterResult) {\n    const tweetId = twitterResult.json.id_str || twitterResult.json.data?.id;\n    if (tweetId) {\n      twitterUrl = `https://twitter.com/i/web/status/${tweetId}`;\n    }\n  }\n} catch (e) {\n  console.log('Twitter URL extraction failed:', e.message);\n}\n\n// Return formatted data for sheet update\nreturn {\n  json: {\n    Status: 'Posted',\n    'Date Posted': new Date().toISOString().split('T')[0] + ' ' + new Date().toTimeString().split(' ')[0],\n    'LinkedIn URL': linkedinUrl,\n    'Twitter URL': twitterUrl,\n    row_number: rowNumber\n  }\n};"},"id":"a99368af-0fdf-45af-9210-fb5979ff20c6","name":"Prepare Success Update","type":"n8n-nodes-base.code","typeVersion":2,"position":[1472,624]},{"parameters":{"operation":"update","documentId":{"__rl":true,"value":"1IzUPSExxerXekGYGavDXOtu2NqwzDg1vOvIwfknL6vU","mode":"id"},"sheetName":{"__rl":true,"mode":"name","value":"Sheet1"},"columns":{"mappingMode":"defineBelow","value":{"Status":"={{ $json.Status }}","Date Posted":"={{ $json['Date Posted'] }}","LinkedIn URL":"={{ $json['LinkedIn URL'] }}","Twitter URL":"={{ $json['Twitter URL'] }}"},"matchingColumns":["row_number"],"schema":[{"id":"Status","displayName":"Status","required":false,"defaultMatch":false,"canBeUsedToMatch":true},{"id":"Date Posted","displayName":"Date Posted","required":false,"defaultMatch":false,"canBeUsedToMatch":true},{"id":"LinkedIn URL","displayName":"LinkedIn URL","required":false,"defaultMatch":false,"canBeUsedToMatch":true},{"id":"Twitter URL","displayName":"Twitter URL","required":false,"defaultMatch":false,"canBeUsedToMatch":true},{"id":"row_number","displayName":"row_number","required":false,"defaultMatch":true,"canBeUsedToMatch":true}]},"options":{}},"id":"656c22a6-58da-40c0-be55-cce1058aa00f","name":"Update Success Status","type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1696,624],"credentials":{"googleSheetsOAuth2Api":{"id":"9VBOHfsYwrDCbXsi","n