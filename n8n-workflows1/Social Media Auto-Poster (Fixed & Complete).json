parameters":[{"name":"Authorization","value":"=Bearer {{ $('Workflow Configuration').first().json.groqApiKey }}"},{"name":"Content-Type","value":"application/json"}]},"sendBody":true,"specifyBody":"json","jsonBody":"={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are an expert social media ghostwriter. Generate engaging, platform-specific content. Always return pure JSON without markdown code blocks or any additional text. Format: {\\\"linkedin_content\\\": \\\"...\\\", \\\"twitter_content\\\": \\\"...\\\"}\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Transform this topic into engaging social media posts:\\n\\nTopic: {{ $json['Content Topic'] }}\\nContext: {{ $json.Notes || 'None provided' }}\\n\\nCreate:\\n1. LinkedIn post (200-300 words): Professional tone, compelling hook, clear value proposition, call-to-action, 3 relevant hashtags\\n2. Twitter post (250-280 characters): Casual tone, catchy, conversational, 2-3 hashtags\\n\\nReturn ONLY valid JSON: {\\\"linkedin_content\\\": \\\"...\\\", \\\"twitter_content\\\": \\\"...\\\"}\"\n    }\n  ],\n  \"max_tokens\": 600,\n  \"temperature\": 0.7\n}","options":{}},"id":"03161fc4-7ae7-4cb3-9eea-ec317463f860","name":"Generate Content with Groq AI","type":"n8n-nodes-base.httpRequest","typeVersion":4.3,"position":[800,208]},{"parameters":{"jsCode":"// Get the Groq API response\nconst response = $input.first().json;\n\ntry {\n  // Extract the AI's message content\n  let aiContent = response.choices[0].message.content;\n  \n  // Clean up any potential markdown formatting\n  aiContent = aiContent.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n  \n  // Parse the JSON\n  const parsedContent = JSON.parse(aiContent);\n  \n  // Validate that we have both required fields\n  if (!parsedContent.linkedin_content || !parsedContent.twitter_content) {\n    throw new Error('Missing required content fields');\n  }\n  \n  // Get original data from Google Sheets\n  const originalData = $('Read Content Queue').first().json;\n  \n  // Return structured output\n  return {\n    json: {\n      linkedin_content: parsedContent.linkedin_content.trim(),\n      twitter_content: parsedContent.twitter_content.trim(),\n      original_topic: originalData['Content Topic'],\n      row_number: originalData.row_number,\n      timestamp: new Date().toISOString(),\n      parsing_success: true\n    }\n  };\n  \n} catch (error) {\n  // If parsing fails, return error data\n  return {\n    json: {\n      parsing_success: false,\n      error_message: error.message,\n      raw_response: response,\n      original_topic: $('Read Content Queue').first().json['Content Topic'],\n      row_number: $('Read Content Queue').first().json.row_number\n    }\n  };\n}"},"id":"3b5fa5d9-a602-47e7-a9f4-499196dd700f","name":"Parse AI Response","type":"n8n-nodes-base.code","typeVersion":2,"position":[1024,208]},{"parameters":{"conditions":{"options":{"caseSensitive":false,"leftValue":"","typeValidation":"loose"},"conditions":[{"id":"id-1","leftValue":"={{ $json.parsing_success }}","rightValue":"true","operator":{"type":"boolean","operation":"true"}}],"combinator":"and"},"options":{}},"id":"de4878af-88bf-4271-bc2c-852623bb36ca","name":"Check Generation Success","type":"n8n-nodes-base.if","typeVersion":2.3,"position":[1248,208]},{"parameters":{"operation":"update","documentId":{"__rl":true,"value":"1IzUPSExxerXekGYGavDXOtu2NqwzDg1vOvIwfknL6vU","mode":"id"},"sheetName":{"__rl":true,"mode":"name","value":"Sheet1"},"columns":{"mappingMode":"defineBelow","value":{"LinkedIn Content":"={{ $json.linkedin_content }}","Twitter Content":"={{ $json.twitter_content }}"},"matchingColumns":["row_number"],"schema":[{"id":"LinkedIn Content","displayName":"LinkedIn Content","required":false,"defaultMatch":false,"canBeUsedToMatch":true},{"id":"Twitter Content","displayName":"Twitter Content","required":false,"defaultMatch":false,"canBeUsedToMatch":true},{"i